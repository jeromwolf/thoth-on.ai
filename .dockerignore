# ── Python 빌드 산출물 ──────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
dist/
build/
*.so

# ── 가상환경 ────────────────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Node 패키지 (console/Dockerfile 에서 npm ci 로 재설치) ─────────────────
console/node_modules/
console/dist/

# ── 데이터 / 로그 (런타임 볼륨으로 관리) ─────────────────────────────────
data/
logs/

# ── 테스트 / CI 캐시 ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── 환경 변수 (시크릿 유출 방지) ───────────────────────────────────────────
.env
.env.local
.env.*.local

# ── 에디터 / OS ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── git ────────────────────────────────────────────────────────────────────
