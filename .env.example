# Copy to .env and adjust.
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=thothpass
NEO4J_DATABASE=neo4j

# Pseudonymization salt (FR-1.3). Change in real deployments.
THOTH_PII_SALT=change-me-in-prod

# LLM explanation provider (FR-5.2). One of: anthropic | openai | ollama | mock
THOTH_LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
