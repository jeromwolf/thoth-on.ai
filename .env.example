# ── THOTH-ON .env 템플릿 ─────────────────────────────────────────────────────
# 복사: cp .env.example .env
# 폐쇄망 배포 전 반드시 민감 값(NEO4J_PASSWORD, THOTH_PII_SALT) 을 변경하라.

# ── Neo4j ────────────────────────────────────────────────────────────────────
# 로컬 개발: bolt://localhost:7688 (docker-compose 포트 매핑)
# 컨테이너 내부 (api 서비스): bolt://neo4j:7687 (docker-compose 자동 주입)
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=thothpass
NEO4J_DATABASE=neo4j

# ── 보안 ─────────────────────────────────────────────────────────────────────
# 가명처리 솔트 (FR-1.3). 프로덕션/온프레미스 배포 시 반드시 변경.
THOTH_PII_SALT=change-me-in-prod

# ── LLM 설명 공급자 (FR-5.2) ─────────────────────────────────────────────────
# 폐쇄망: ollama (로컬 LLM) 또는 mock (LLM 없이 규칙 기반 설명)
# 선택: anthropic | openai | ollama | mock
THOTH_LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Ollama (폐쇄망 LLM) ───────────────────────────────────────────────────────
# 온프레미스 폐쇄망에서 외부 LLM 대신 Ollama 사용 시 설정.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# ── API 서버 ──────────────────────────────────────────────────────────────────
# THOTH_API_HOST: 컨테이너 실행 시 docker-compose 에서 0.0.0.0 으로 덮어씀
THOTH_API_HOST=127.0.0.1
THOTH_API_PORT=8468

# ── Console (nginx) ──────────────────────────────────────────────────────────
# 호스트에서 콘솔에 접근하는 포트 (nginx → :80 매핑)
THOTH_CONSOLE_PORT=8469
